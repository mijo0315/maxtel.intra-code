Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    ############################################################
    # BLOCK SENSITIVE FILES
    ############################################################

    RewriteRule (^|/)\.env$ - [F,L,NC]
    RewriteRule ^composer\.json$ - [F,L,NC]
    RewriteRule ^composer\.lock$ - [F,L,NC]
    RewriteRule ^artisan$ - [F,L,NC]
    RewriteRule ^package\.json$ - [F,L,NC]
    RewriteRule ^phpunit\.xml$ - [F,L,NC]
    RewriteRule ^server\.php$ - [F,L,NC]

    ############################################################
    # BLOCK SENSITIVE DIRECTORIES
    ############################################################

    RewriteRule ^vendor(/.*)?$ - [F,L,NC]
    RewriteRule ^storage(/.*)?$ - [F,L,NC]
    RewriteRule ^bootstrap(/.*)?$ - [F,L,NC]
    RewriteRule ^config(/.*)?$ - [F,L,NC]
    RewriteRule ^database(/.*)?$ - [F,L,NC]
    RewriteRule ^resources(/.*)?$ - [F,L,NC]
    RewriteRule ^routes(/.*)?$ - [F,L,NC]
    RewriteRule ^tests(/.*)?$ - [F,L,NC]

    ############################################################
    # HANDLE AUTHORIZATION HEADER
    ############################################################

    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    ############################################################
    # REDIRECT TRAILING SLASHES
    ############################################################

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    ############################################################
    # SEND TO LARAVEL
    ############################################################

    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

</IfModule>